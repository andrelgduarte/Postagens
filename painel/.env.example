# Instagram Graph API
META_ACCESS_TOKEN=          # Page Access Token (longa duração / permanente)
META_IG_USER_ID=            # ID da conta IG Business (numérico, ex: 17841...)
META_GRAPH_VERSION=v22.0    # Opcional. Default: v22.0

# Vercel Blob (hospedagem temporária das imagens enquanto o IG baixa)
BLOB_READ_WRITE_TOKEN=      # vercel_blob_rw_xxx (criado em vercel.com/storage/blob)
